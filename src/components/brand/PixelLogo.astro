---
interface Props {
  class?: string
  label?: string
}

const { class: className = "", label = "Logo b slash greater" } = Astro.props as Props
---

<span class={`pixel-logo ${className}`} role="img" aria-label={label}>
  <svg
    viewBox="0 0 96 32"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    shape-rendering="crispEdges"
    fill="currentColor"
    focusable="false"
  >
    <!-- b minuscula -->
    <rect x="0" y="0" width="8" height="32" />
    <rect x="8" y="12" width="12" height="6" />
    <rect x="8" y="24" width="12" height="8" />
    <rect x="20" y="20" width="8" height="6" />

    <!-- / -->
    <rect x="48" y="24" width="4" height="4" />
    <rect x="52" y="20" width="4" height="4" />
    <rect x="56" y="16" width="4" height="4" />
    <rect x="60" y="12" width="4" height="4" />
    <rect x="64" y="8" width="4" height="4" />
    <rect x="68" y="4" width="4" height="4" />

    <!-- > -->
    <rect x="76" y="8" width="4" height="4" />
    <rect x="80" y="12" width="4" height="4" />
    <rect x="84" y="16" width="4" height="4" />
    <rect x="80" y="20" width="4" height="4" />
    <rect x="76" y="24" width="4" height="4" />
  </svg>
</span>
