---
import Layout from "../layouts/Layout.astro"

const pageTitle = "Panel interno de publicaciones"
const pageDescription = "Ruta privada para publicar articulos en el blog de BYTTES."
---

<Layout title={pageTitle} description={pageDescription} canonicalPath="/panel-interno-7f3a" noindex={true}>
  <main class="terminal-page private-publish-page">
    <section class="shell-window">
      <div class="shell-window__bar">
        <span class="terminal-dot terminal-dot--red"></span>
        <span class="terminal-dot terminal-dot--yellow"></span>
        <span class="terminal-dot terminal-dot--green"></span>
        <p class="shell-window__path">root@byttes:/panel-interno-7f3a</p>
      </div>

      <div class="shell-window__content private-publish-panel">
        <p class="prompt-line"><span class="prompt">$</span> publish --secure --channel=blog</p>
        <h1>Panel interno</h1>
        <p class="lead">Publica articulos directamente en el blog. Se requiere contrasena privada.</p>

        <form id="private-publish-form" class="private-publish-form" autocomplete="off">
          <label>
            Titulo
            <input name="title" type="text" required minlength="8" maxlength="120" />
          </label>

          <label>
            Descripcion SEO
            <input name="description" type="text" required minlength="20" maxlength="180" />
          </label>

          <label>
            Autor
            <input name="author" type="text" value="Equipo BYTTES" maxlength="80" />
          </label>

          <label>
            Tags (separados por coma)
            <input name="tags" type="text" placeholder="seo, automatizacion, pymes" maxlength="120" />
          </label>

          <label>
            Contenido (Markdown)
            <textarea name="content" rows="14" required minlength="40"></textarea>
          </label>

          <label>
            Contrasena privada
            <input name="password" type="password" required minlength="6" autocomplete="new-password" />
          </label>

          <button class="btn-terminal" type="submit">Publicar ahora</button>
        </form>

        <p id="publish-status" class="private-publish-status" role="status" aria-live="polite"></p>
      </div>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById("private-publish-form")
  const statusNode = document.getElementById("publish-status")

  if (form instanceof HTMLFormElement && statusNode instanceof HTMLElement) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault()

      const formData = new FormData(form)

      const payload = {
        title: String(formData.get("title") ?? ""),
        description: String(formData.get("description") ?? ""),
        author: String(formData.get("author") ?? "Equipo BYTTES"),
        tags: String(formData.get("tags") ?? "")
          .split(",")
          .map((tag) => tag.trim())
          .filter(Boolean),
        content: String(formData.get("content") ?? ""),
        password: String(formData.get("password") ?? ""),
      }

      statusNode.textContent = "Publicando..."

      try {
        const response = await fetch("/api/private-publish", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        })

        const result = (await response.json()) as { error?: string; file?: string; url?: string }

        if (!response.ok) {
          statusNode.textContent = result.error ?? "No se pudo publicar."
          return
        }

        statusNode.textContent = `Publicado: ${result.file} (${result.url})`
        form.reset()
      } catch {
        statusNode.textContent = "Error de red al publicar."
      }
    })
  }
</script>

<style>
  .private-publish-page {
    padding-top: 2rem;
  }

  .private-publish-panel {
    display: grid;
    gap: 1rem;
  }

  .private-publish-form {
    display: grid;
    gap: 0.85rem;
  }

  .private-publish-form label {
    display: grid;
    gap: 0.3rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .private-publish-form input,
  .private-publish-form textarea {
    width: 100%;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-1) 78%, black 22%);
    color: var(--text-main);
    border-radius: 8px;
    padding: 0.6rem 0.7rem;
    font: inherit;
  }

  .private-publish-form textarea {
    resize: vertical;
    min-height: 220px;
  }

  .private-publish-form input:focus,
  .private-publish-form textarea:focus {
    outline: 1px solid color-mix(in oklab, var(--accent) 65%, var(--line));
    border-color: color-mix(in oklab, var(--accent) 65%, var(--line));
  }

  .private-publish-status {
    min-height: 1.3rem;
    color: var(--accent-2);
    margin: 0;
  }
</style>
